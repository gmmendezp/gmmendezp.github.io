{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "files": {
    "includes": [
      "**/src/**/*.tsx",
      "**/src/**/*.ts",
      "**/*.js",
      "!**/cosmos-export",
      "!**/dist",
      "!**/dist-ssr"
    ]
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": false
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  }
}
